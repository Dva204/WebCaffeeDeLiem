@model Web_CuaHangCafe.Models.TbKhachHang
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "Hồ sơ cá nhân";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Breadcrumb -->
<div class="breadcrumb-option">
    <div class="container">
        <div class="breadcrumb__links">
            <a asp-controller="home" asp-action="index"><i class="fa-solid fa-house"></i> Trang chủ</a>
            <span>Hồ sơ cá nhân</span>
        </div>
    </div>
</div>

<section class="spad">
    <div class="container">

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }
        @if (TempData["ErrorPass"] != null)
        {
            <div class="alert alert-danger">@TempData["ErrorPass"]</div>
        }

        <div class="row">

            <!-- ── Thông tin cá nhân ── -->
            <div class="col-lg-6 mb-5">
                <h5 class="mb-3">Thông tin cá nhân</h5>
                <form asp-action="Profile" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label">Họ và tên</label>
                        <input asp-for="TenKhachHang" class="form-control" placeholder="Nhập họ tên" />
                        <span asp-validation-for="TenKhachHang" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" class="form-control" value="@Model.Email" disabled />
                        <small class="text-muted">Email không thể thay đổi</small>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Số điện thoại</label>
                        <input asp-for="SdtkhachHang" class="form-control"
                               maxlength="10" placeholder="Nhập số điện thoại" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Địa chỉ</label>
                        <input asp-for="DiaChi" class="form-control" placeholder="Nhập địa chỉ" />
                    </div>

                    <button type="submit" class="site-btn">Lưu thay đổi</button>
                </form>
            </div>

            <!-- ── Đổi mật khẩu ── -->
            <div class="col-lg-6 mb-5">
                <h5 class="mb-3">Đổi mật khẩu</h5>
                <form asp-action="ChangePassword" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label">Mật khẩu hiện tại</label>
                        <input type="password" name="matKhauCu" class="form-control"
                               placeholder="Nhập mật khẩu cũ" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Mật khẩu mới</label>
                        <input type="password" name="matKhauMoi" class="form-control"
                               placeholder="Ít nhất 6 ký tự" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Xác nhận mật khẩu mới</label>
                        <input type="password" name="xacNhan" class="form-control"
                               placeholder="Nhập lại mật khẩu mới" required />
                    </div>

                    <button type="submit" class="site-btn">Đổi mật khẩu</button>
                </form>
            </div>

            <!-- ── Link sang đơn hàng ── -->
            <div class="col-lg-12">
                <a asp-action="Orders" class="primary-btn">
                    <i class="fas fa-list-ul"></i> Xem đơn hàng của tôi
                </a>
            </div>

        </div>
    </div>
</section>