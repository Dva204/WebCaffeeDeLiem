@model Web_CuaHangCafe.ViewModels.LoginViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Đăng nhập</title>

    <style>
        body {
            margin: 0;
            font-family: Arial;
            background: linear-gradient(135deg, #6b4f4f, #c2a383);
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .login-box {
            background: #fff;
            padding: 40px;
            width: 350px;
            border-radius: 10px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.2);
        }

            .login-box h2 {
                text-align: center;
                margin-bottom: 20px;
            }

        .input-group {
            margin-bottom: 15px;
        }

            .input-group label {
                display: block;
                margin-bottom: 5px;
            }

            .input-group input {
                width: 100%;
                padding: 10px;
                border: 1px solid #ccc;
                border-radius: 5px;
            }

        .btn-login {
            width: 100%;
            padding: 10px;
            background: #6b4f4f;
            color: #fff;
            border: none;
            border-radius: 5px;
            cursor: pointer;
        }

            .btn-login:hover {
                background: #5a3f3f;
            }

        .error {
            color: red;
            text-align: center;
            margin-top: 10px;
        }

        .link {
            text-align: center;
            margin-top: 15px;
        }
    </style>
</head>

<body>

    <div class="login-box">
        <h2>Đăng nhập</h2>

        <form asp-action="Login" method="post">

            <div class="input-group">
                <label>Email</label>
                <input asp-for="Email" />
            </div>

            <div class="input-group">
                <label>Mật khẩu</label>
                <input asp-for="MatKhau" type="password" />
            </div>

            <button type="submit" class="btn-login">Đăng nhập</button>

            <div class="error">
                @ViewBag.Error
            </div>

            <div class="link">
                <a asp-action="Register">Chưa có tài khoản? Đăng ký</a>
            </div>

        </form>
    </div>

</body>
</html>