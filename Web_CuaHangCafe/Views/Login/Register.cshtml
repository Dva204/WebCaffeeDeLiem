@model Web_CuaHangCafe.ViewModels.RegisterViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Đăng ký</title>

    <style>
        body {
            margin: 0;
            font-family: Arial;
            background: linear-gradient(135deg, #6b4f4f, #c2a383);
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .register-box {
            background: #fff;
            padding: 30px;
            width: 380px;
            border-radius: 10px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.2);
        }

            .register-box h2 {
                text-align: center;
                margin-bottom: 20px;
            }

        .input-group {
            margin-bottom: 12px;
        }

            .input-group label {
                display: block;
                margin-bottom: 5px;
            }

            .input-group input {
                width: 100%;
                padding: 10px;
                border: 1px solid #ccc;
                border-radius: 5px;
            }

        .btn-register {
            width: 100%;
            padding: 10px;
            background: #6b4f4f;
            color: #fff;
            border: none;
            border-radius: 5px;
            cursor: pointer;
        }

            .btn-register:hover {
                background: #5a3f3f;
            }

        .error {
            color: red;
            text-align: center;
            margin-top: 10px;
        }

        .link {
            text-align: center;
            margin-top: 15px;
        }
    </style>
</head>

<body>

    <div class="register-box">
        <h2>Đăng ký</h2>

        <form asp-action="Register" method="post">

            <div class="input-group">
                <label>Tên khách hàng</label>
                <input asp-for="TenKhachHang" />
            </div>

            <div class="input-group">
                <label>SĐT</label>
                <input asp-for="SdtkhachHang" />
            </div>

            @*<div class="input-group">
                <label>Địa chỉ</label>
                <input asp-for="DiaChi" />
            </div>*@

            <div class="input-group">
                <label>Email</label>
                <input asp-for="Email" />
            </div>

            <div class="input-group">
                <label>Mật khẩu</label>
                <input asp-for="MatKhau" type="password" />
            </div>

            <div class="input-group">
                <label>Xác nhận mật khẩu</label>
                <input asp-for="XacNhanMatKhau" type="password" />
            </div>

            <button type="submit" class="btn-register">Đăng ký</button>

            <div class="error">
                @ViewBag.Error
            </div>

            <div class="link">
                <a asp-action="Login">Đã có tài khoản? Đăng nhập</a>
            </div>

        </form>
    </div>

</body>
</html>